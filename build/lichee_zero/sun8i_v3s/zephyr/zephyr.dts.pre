/ {
 model = "Sipeed Lichee Zero";
 compatible = "sipeed,lichee-zero", "allwinner,sun8i-v3s";

 chosen {
  zephyr,console = &uart0;
  zephyr,shell-uart = &uart0;
  zephyr,sram = &ddr0;
  zephyr,entropy = &rng;
  zephyr,display = &mixer0;
 };

 lvgl_pointer {
  compatible = "zephyr,lvgl-pointer-input";
  input = <&ns2009>;
 };

 leds {
  compatible = "gpio-leds";
  green_led: led_0 {
   gpios = <&gpiog 0 (1 << 0)>;
   label = "Green LED";
  };
  blue_led: led_1 {
   gpios = <&gpiog 1 (1 << 0)>;
   label = "Blue LED";
  };
  red_led: led_2 {
   gpios = <&gpiog 2 (1 << 0)>;
   label = "Red LED";
  };
 };
};

&uart0 {
 pinctrl-0 = <&uart0_pins>;
 pinctrl-names = "default";
 status = "okay";
 current-speed = <115200>;
};

&timer0 {
 status = "okay";

 counter0: counter@0 {
  status = "okay";
 };
};

&pinctrl {
 status = "okay";

