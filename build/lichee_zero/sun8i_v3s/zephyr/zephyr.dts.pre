  i2c0_pins: i2c0-pins {
   pinmux = <(((1) << 5) | ((6) << 0) | ((2) << 8))>,
     <(((1) << 5) | ((7) << 0) | ((2) << 8))>;
  };

  pwm_pins: pwm-pins {
   pinmux = <(((1) << 5) | ((4) << 0) | ((2) << 8))>,
     <(((1) << 5) | ((5) << 0) | ((2) << 8))>;
  };

  spi0_pins: spi0-pins {
   pinmux = <(((2) << 5) | ((0) << 0) | ((3) << 8))>,
     <(((2) << 5) | ((1) << 0) | ((3) << 8))>,
     <(((2) << 5) | ((2) << 0) | ((3) << 8))>,
     <(((2) << 5) | ((3) << 0) | ((3) << 8))>;
  };

  uart0_pins: uart0-pins {
   pinmux = <(((1) << 5) | ((8) << 0) | ((3) << 8))>,
      <(((1) << 5) | ((9) << 0) | ((3) << 8))>;
   drive-strength = <3>;
   allwinner,pull = "pull_up";
  };

  mmc0_pins: mmc0-pins {
   pinmux = <(((5) << 5) | ((0) << 0) | ((2) << 8))>,
     <(((5) << 5) | ((1) << 0) | ((2) << 8))>,
     <(((5) << 5) | ((2) << 0) | ((2) << 8))>,
