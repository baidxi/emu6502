/ {
 interrupt-parent = <&gic>;
 #address-cells = <1>;
 #size-cells = <1>;

 aliases {
  sdhc0 = &mmc0;
  sdhc1 = &mmc1;
  sdhc2 = &mmc2;
 };

 cpus {
  #address-cells = <1>;
  #size-cells = <0>;

  cpu0: cpu@0 {
   compatible = "arm,cortex-a7";
   device_type = "cpu";
   reg = <0>;
   clock-frequency = <(((1008) * 1000) * 1000)>;
  };
 };

 arch_timer: timer {
  compatible = "arm,armv8-timer";
  clock-frequency = <(((24) * 1000) * 1000)>;
  status = "okay";
  interrupts = <0x1 13 (1UL << (1)) 0xa0>,
        <0x1 14 (1UL << (1)) 0xa0>,
        <0x1 11 (1UL << (1)) 0xa0>,
        <0x1 10 (1UL << (1)) 0xa0>;
  interrupt-parent = <&gic>;
 };


 osc24M: osc24M {
  compatible = "fixed-clock";
  clock-frequency = <24000000>;
  #clock-cells = <0>;
  #clock-source-cells = <0>;
 };

 osc32k: osc32k {
  compatible = "fixed-clock";
  clock-frequency = <32768>;
  #clock-cells = <0>;
 };

 soc {
  compatible = "simple-bus";
  #address-cells = <1>;
  #size-cells = <1>;
  ranges;

  sram0: memory@40000 {
   device_type = "memory";
   compatible = "zephyr,memory-region", "mmio-sram";
   reg = <0x40000 ((44) * 1024)>;
   zephyr,memory-region = "SRAM0";
  };

  ddr0: memory@40000000 {
   device_type = "memory";
   reg = <0x40000000 (((64) * 1024) * 1024)>;
  };

  syscon: system-control@1c00000 {
   compatible = "syscon";
   reg = <0x01c00000 0xd0>;
   status = "okay";
  };

  rtc: rtc@1c20400 {
   compatible = "allwinner,sun8i-v3-rtc";
   reg = <0x01c20400 0x400>;
   interrupts = <0x0 40 (1UL << (1)) 0xa0>,
         <0x0 41 (1UL << (1)) 0xa0>;
   clocks = <&osc32k>;
   alarms-count = <1>;
   status = "disabled";
  };

  ccu: clock-controller@1c20000 {
   compatible = "allwinner,sun8i-v3s-ccu";
   status = "okay";
   reg = <0x01c20000 0x400>;
   clocks = <&osc24M>, <&osc32k>;
   clock-names = "hosc", "losc";
   #clock-cells = <1>;
   #reset-cells = <1>;
   reset: reset-controller {
    compatible = "allwinner,sun8i-v3s-ccu-reset";
    #reset-cells = <1>;
    status = "okay";
   };
  };

  gic: interrupt-controller@1c81000 {
   compatible = "arm,gic-400", "arm,gic-v2", "arm,gic";
   status = "okay";
   reg = <0x01c81000 0x1000>,
         <0x01c82000 0x2000>,
         <0x01c84000 0x2000>,
         <0x01c86000 0x2000>;
   interrupt-controller;
   #interrupt-cells = <4>;
   #address-cells = <0>;
  };

  uart0: uart@1c28000 {
   compatible = "ns16550", "snps,dw-apb-uart";
   reg = <0x01c28000 0x400>;
   reg-shift = <2>;
   interrupts = <0x0 0 (1UL << (1))
          0xa0>;
   clock-frequency = <(((24) * 1000) * 1000)>;
   dmas = <&dma 6>,
          <&dma 6>;
   dma-names = "tx", "rx";
   status = "disabled";
  };

  uart1: uart@1c28400 {
   compatible = "ns16550", "snps,dw-apb-uart";
   reg = <0x01c28400 0x400>;
   reg-shift = <2>;
   interrupts = <0x0 1 (1UL << (1))
          0xa0>;
   clock-frequency = <(((24) * 1000) * 1000)>;
   dmas = <&dma 7>,
          <&dma 7>;
   dma-names = "tx", "rx";
   status = "disabled";
  };

  uart2: uart@1c28800 {
   compatible = "ns16550", "snps,dw-apb-uart";
   reg = <0x01c28800 0x400>;
   reg-shift = <2>;
   interrupts = <0x0 2 (1UL << (1))
          0xa0>;
   clock-frequency = <(((24) * 1000) * 1000)>;
   dmas = <&dma 8>,
          <&dma 8>;
   dma-names = "tx", "rx";
   status = "disabled";
  };

  pinctrl: pinctrl@1c20800 {
   compatible = "allwinner,sun8i-v3s-pinctrl";
   reg = <0x01c20800 0x400>;
   clocks = <&ccu 37>,<&osc24M>, <&osc32k>;
   clock-names = "bus","hosc","losc";
   #address-cells = <1>;
   #size-cells = <0>;
   status = "disabled";
   gpiob: gpio@1 {
    compatible = "allwinner,sun8i-v3s-gpio";
    reg = <1>;
    interrupts = <0x0 15 (1UL << (1)) 0xa0>;
    gpio-controller;
    #gpio-cells = <2>;
    interrupt-controller;
    #interrupt-cells = <2>;
    status = "disabled";
   };
   gpioc: gpio@2 {
    compatible = "allwinner,sun8i-v3s-gpio";
    reg = <2>;
    gpio-controller;
    #gpio-cells = <2>;
    status = "disabled";
   };
   gpiod: gpio@3 {
    compatible = "allwinner,sun8i-v3s-gpio";
    reg = <3>;
    gpio-controller;
    #gpio-cells = <2>;
    status = "disabled";
   };
   gpioe: gpio@4 {
    compatible = "allwinner,sun8i-v3s-gpio";
    reg = <4>;
    gpio-controller;
    #gpio-cells = <2>;
    status = "disabled";
   };
   gpiof: gpio@5 {
    compatible = "allwinner,sun8i-v3s-gpio";
    reg = <5>;
    gpio-controller;
    #gpio-cells = <2>;
    status = "disabled";
   };
   gpiog: gpio@6 {
    compatible = "allwinner,sun8i-v3s-gpio";
    reg = <6>;
    interrupts = <0x0 17 (1UL << (1)) 0xa0>;
    gpio-controller;
    #gpio-cells = <2>;
    interrupt-controller;
    #interrupt-cells = <2>;
    status = "disabled";
   };
  };

  dma: dma-controller@1c02000 {
   compatible = "allwinner,sun8i-v3s-dma";
   reg = <0x01c02000 0x1000>;
   interrupts = <0x0 50 (1UL << (1))
      0xa0>;
   clocks = <&ccu 21>;
   resets = <&reset 6>;
   #dma-cells = <1>;
   dma-channels = <8>;
   dma-requests = <24>;
   status = "okay";
  };

  timer0: timer@1c20c00 {
   compatible = "allwinner,sun8i-v3s-timer";
   reg = <0x01c20c00 0xdc>;
   clocks = <&osc24M>;
   #address-cells = <1>;
   #size-cells = <0>;
   interrupts = <0x0 18 (1UL << (1)) 0xa0>,
         <0x0 19 (1UL << (1)) 0xa0>,
         <0x0 20 (1UL << (1)) 0xa0>;
   status = "disabled";

   counter0: counter@0 {
    compatible = "allwinner,sun8i-v3s-counter";
    reg = <0>;
    clocks = <&osc24M>;
    clock-source = <1>;
    prescaler = <0>;
    status = "disabled";
   };

   counter1: counter@1 {
    compatible = "allwinner,sun8i-v3s-counter";
    reg = <1>;
    clocks = <&osc24M>;
    clock-source = <1>;
    prescaler = <0>;
    status = "disabled";
   };

   counter2: counter@2 {
    compatible = "allwinner,sun8i-v3s-counter";
    reg = <2>;
    clocks = <&osc24M>;
    clock-source = <1>;
    prescaler = <0>;
    status = "disabled";
   };

   avs0: avs {
    compatible = "allwinner,sun8i-v3s-avs";
    divisor = <1499>;
    status = "disabled";
   };
  };

  pwm: pwm@1c21400 {
   compatible = "allwinner,sun8i-v3s-pwm";
   reg = <0x01c21400 0x400>;
   #pwm-cells = <2>;
   status = "disabled";
  };

  spi0: spi@1c68000 {
   compatible = "allwinner,sun8i-v3s-spi";
   reg = <0x01c68000 0x1000>;
   interrupts = <0x0 65 (1UL << (1)) 0xa0>;
   clocks = <&ccu 28>, <&ccu 55>;
   clock-names = "bus", "mod";
   resets = <&reset 15>;
   clock-frequency = <(((24) * 1000) * 1000)>;
   dmas = <&dma 23>, <&dma 23>;
   dma-names = "tx", "rx";
   #address-cells = <1>;
   #size-cells = <0>;
   status = "disabled";
  };

  i2c0: i2c@1c2ac00 {
   compatible = "allwinner,sun8i-v3s-i2c";
   reg = <0x01c2ac00 0x400>;
   interrupts = <0x0 6 (1UL << (1)) 0xa0>;
   clocks = <&ccu 38>;
   clock-names = "bus";
   resets = <&reset 46>;
   clock-frequency = <100000>;
   #address-cells = <1>;
   #size-cells = <0>;
   status = "disabled";
  };

  i2c1: i2c@1c2b000 {
   compatible = "allwinner,sun8i-v3s-i2c";
   reg = <0x01c2b000 0x400>;
   interrupts = <0x0 7 (1UL << (1)) 0xa0>;
   clocks = <&ccu 39>;
   clock-names = "bus";
   resets = <&reset 47>;
   clock-frequency = <100000>;
   #address-cells = <1>;
   #size-cells = <0>;
   status = "disabled";
  };

  usbphy: phy@1c19400 {
   compatible = "allwinner,sun8i-v3s-usb-phy", "allwinner,sun4i-usb-phy";
   reg = <0x01c19400 0x2c>, <0x01c1a800 0x4>;
   reg-names = "phy_ctrl", "pmu0";
   clocks = <&ccu 56>;
   clock-names = "usb0_phy";
   resets = <&reset 0>;
   reset-names = "usb0_reset";
   #phy-cells = <1>;
   status = "disabled";
  };

  mmc0: mmc@1c0f000 {
   compatible = "allwinner,sunxi-mmc";
   reg = <0x01c0f000 0x1000>;
   clocks = <&ccu 22>, <&ccu 45>,
     <&ccu 47>, <&ccu 46>;
   clock-names = "ahb", "mmc", "output", "sample";
   resets = <&reset 7>;
   reset-names = "ahb";
   interrupts = <0x0 60 (1UL << (1)) 0xa0>;
   bus-width = <4>;
   max-bus-freq = <50000000>;
   min-bus-freq = <400000>;
   status = "disabled";
  };

  mmc1: mmc@1c10000 {
   compatible = "allwinner,sunxi-mmc";
   reg = <0x01c10000 0x1000>;
   clocks = <&ccu 23>, <&ccu 48>,
     <&ccu 50>, <&ccu 49>;
   clock-names = "ahb", "mmc", "output", "sample";
   resets = <&reset 8>;
   reset-names = "ahb";
   interrupts = <0x0 61 (1UL << (1)) 0xa0>;
   bus-width = <4>;
   max-bus-freq = <50000000>;
   min-bus-freq = <400000>;
   status = "disabled";
  };

  mmc2: mmc@1c11000 {
   compatible = "allwinner,sunxi-mmc";
   reg = <0x01c11000 0x1000>;
   clocks = <&ccu 24>, <&ccu 51>,
     <&ccu 53>, <&ccu 52>;
   clock-names = "ahb", "mmc", "output", "sample";
   resets = <&reset 9>;
   reset-names = "ahb";
   interrupts = <0x0 62 (1UL << (1)) 0xa0>;
   bus-width = <1>;
   max-bus-freq = <50000000>;
   min-bus-freq = <400000>;
   status = "disabled";
  };

  crypto: crypto@1c15000 {
   compatible = "allwinner,sun8i-v3s-crypto";
   reg = <0x01c15000 0x1000>;
   interrupts = <0x0 80 (1UL << (1)) 0xa0>;
   clocks = <&ccu 20>, <&ccu 54>;
   clock-names = "ahb", "mod";
   resets = <&reset 5>;
   reset-names = "ahb";
   dmas = <&dma 16>,
          <&dma 16>;
   dma-names = "rx", "tx";
   status = "disabled";

   rng: rng {
    compatible = "allwinner,sun8i-v3s-rng";
    status = "disabled";
   };
  };

  usbotg: usb@1c19000 {
   compatible = "allwinner,sun8i-v3s-musb";
   reg = <0x01c19000 0x0400>;
   interrupts = <0x0 71 (1UL << (1)) 0xa0>;
   phys = <&usbphy 0>;
   clocks = <&ccu 29>;
   resets = <&reset 17>;
   num-bidir-endpoints = <5>;
   status = "disabled";
  };

  codec: codec@1c22c00 {
   compatible = "allwinner,sun8i-v3s-codec";
   reg = <0x01c22c00 0x400>;
   interrupts = <0x0 29 (1UL << (1)) 0xa0>;
   clocks = <&ccu 36>, <&ccu 70>;
   clock-names = "apb", "codec";
   resets = <&reset 40>;
   dmas = <&dma 15>,
          <&dma 15>;
   dma-names = "rx", "tx";
   allwinner,codec-analog-controls = <&codec_analog>;
   status = "disabled";
  };

  codec_analog: codec-analog@1c23000 {
   compatible = "allwinner,sun8i-v3s-codec-analog";
   reg = <0x01c23000 0x4>;
  };

  emac: ethernet@1c30000 {
   compatible = "allwinner,sun8i-v3s-emac";
   reg = <0x01c30000 0x10000>;
   interrupts = <0x0 82 (1UL << (1)) 0xa0>;
   clocks = <&ccu 26>;
   resets = <&reset 12>;
   allwinner,phy-addr = <1>;
   phy-handle = <&int_mii_phy>;
   phy-connection-type = "mii";
   status = "disabled";

   mdio: mdio {
    compatible = "allwinner,sun8i-v3s-mdio";
    #address-cells = <1>;
    #size-cells = <0>;

    int_mii_phy: ethernet-phy@1 {
      compatible = "ethernet-phy";
      reg = <1>;
      default-speeds = "10BASE Full-Duplex",
         "100BASE Full-Duplex";
     };
   };
  };

  display_clocks: clock@1000000 {
   compatible = "allwinner,sun8i-v3s-de2-clk";
   reg = <0x01000000 0x10000>;
   clocks = <&ccu 35>,
     <&ccu 63>;
   clock-names = "bus",
          "mod";
   resets = <&reset 34>;
   #clock-cells = <1>;
   status = "disabled";

   de2_reset: reset-controller {
    compatible = "allwinner,sun8i-de2-reset";
    #reset-cells = <1>;
   };
  };

  mixer0: mixer@1100000 {
   compatible = "allwinner,sun8i-v3s-de2-mixer";
   reg = <0x01100000 0x100000>;
   clocks = <&display_clocks 0>,
     <&display_clocks 6>;
   clock-names = "bus",
          "mod";
   resets = <&de2_reset 0>;
   tcon = <&tcon0>;
   status = "disabled";
  };

  tcon0: tcon@1c0c000 {
   compatible = "allwinner,sun8i-v3s-tcon";
   reg = <0x01c0c000 0x1000>;
   interrupts = <0x0 86 (1UL << (1)) 0xa0>;
   clocks = <&ccu 33>,
     <&ccu 64>;
   clock-names = "ahb",
          "tcon-ch0";
   resets = <&reset 27>;
   reset-names = "lcd";
   status = "disabled";
  };
 };
};
